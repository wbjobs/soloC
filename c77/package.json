{
  "name": "protein-md-simulator",
  "version": "1.0.0",
  "description": "Protein Molecular Dynamics Simulator with 3D Visualization",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "three.js",
    "protein",
    "molecular-dynamics",
    "openmm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "three": "^0.160.0",
    "axios": "^1.6.0",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.proteinmd.simulator",
    "productName": "Protein MD Simulator",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  }
}
