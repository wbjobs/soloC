# Server Configuration
PORT=3000
NODE_ENV=development

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=radio-signal-processor
KAFKA_TOPIC_TASKS=signal-processing-tasks
KAFKA_TOPIC_RESULTS=signal-processing-results
KAFKA_GROUP_ID=processing-workers

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=radio-astronomy
INFLUXDB_BUCKET=signal-processing-metrics

# Data Storage
DATA_DIR=./data
RESULTS_DIR=./results

# Processing Configuration
FFT_WINDOW_SIZE=1024
PRESTO_NUM_PERIODS=1000
MIN_SNR_THRESHOLD=5.0
