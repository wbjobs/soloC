{
  "name": "dedup-fs-explorer",
  "version": "1.0.0",
  "description": "Cross-platform desktop app for deduplicated file system visualization",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:electron\"",
    "start:backend": "python backend/fs_server.py",
    "start:electron": "electron .",
    "dev": "concurrently \"npm run start:backend\" \"npm run dev:react\"",
    "dev:react": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "electron": "^28.0.0",
    "concurrently": "^8.2.0"
  }
}
